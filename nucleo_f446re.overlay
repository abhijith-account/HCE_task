/* Enable the I2C1 Bus */
&i2c1 {
    status = "okay";
    
    /* SMBus requires 100 kHz for the Smart Battery */
    clock-frequency = <I2C_BITRATE_STANDARD>; 

    /* 1. LPS22HB Pressure Sensor */
    lps22hb: lps22hb@5c {
        compatible = "st,lps22hb-press";
        reg = <0x5c>; 
        status = "okay";
    };

    /* 2. BME280 Environmental Sensor */
    bme280: bme280@76 {
        compatible = "bosch,bme280";
        reg = <0x76>; /* Note: Can also be 0x77 depending on the SDO pin wiring */
        status = "okay";
    };

    /* 4. PAV3015 Air Velocity / Flow Sensor */
    pav3015: pav3015@50 {
        compatible = "vnd,i2c-device"; /* Generic I2C device binding if no dedicated Zephyr driver exists */
        reg = <0x50>; /* Note: Verify and replace 0x50 with the exact address from your specific module's datasheet */
        status = "okay";
    };
};

/* Enable the UART for Daly Smart BMS */
&usart2 { /* Note: Change '&usart2' to the actual UART/USART node your BMS is wired to */
    status = "okay";
    current-speed = <9600>; /* Daly BMS typically communicates at 9600 baud */

    daly_bms: daly_bms {
        compatible = "daly,bms";
        status = "okay";
    };
};

&iwdg {
    status = "okay";
};

/ {
    aliases {
        cdc-acm-uart0 = &cdc_acm_uart0;
        bms = &daly_bms; /* Added alias for application-level access to the BMS */
    };
};

&usbotg_fs {
    status = "okay";
    pinctrl-0 = <&usb_otg_fs_dm_pa11 &usb_otg_fs_dp_pa12>;
    pinctrl-names = "default";

    cdc_acm_uart0: cdc_acm_uart0 {
        compatible = "zephyr,cdc-acm-uart";
    };
};
